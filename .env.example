# Flask
PORT=5000
FLASK_HOST=127.0.0.1
# Public domain used in generated short URLs
# SHORT_BASE_URL=https://urlshortner.ly

# MongoDB (Atlas recommended)
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_DB=url_shortener
MONGO_COLLECTION=urls

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS (only needed if frontend served separately)
CORS_ORIGINS=*

# Frontend (Vite)
# If you run Vite separately, set this to your Flask server (e.g. http://localhost:5000)
# If Flask serves the built frontend, you can leave it empty.
VITE_API_BASE_URL=
